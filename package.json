{
  "name": "netmon",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate": "prisma migrate deploy --schema=packages/database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/database/prisma/schema.prisma",
    "docker:dev": "docker compose --env-file .env -f infra/docker-compose.dev.yml up -d",
    "docker:dev:build": "docker compose --env-file .env -f infra/docker-compose.dev.yml up --build -d",
    "docker:down": "docker compose --env-file .env -f infra/docker-compose.dev.yml down"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"commonjs\"} packages/database/prisma/seed.ts"
  },
  "packageManager": "npm@10.8.0"
}