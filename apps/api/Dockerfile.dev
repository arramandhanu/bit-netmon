# ─── NetMon API — Unified Dockerfile ─────────────────
# Dev:  docker compose -f infra/docker-compose.dev.yml up
# Prod: docker compose -f infra/docker-compose.prod.yml up
#
# Build arg BUILD_ENV controls the behavior:
#   development → hot-reload with nest start --watch
#   production  → multi-stage optimized build

ARG BUILD_ENV=development

# ════════════════════════════════════════════════════════
# Stage 1: Dependencies only (maximizes layer cache)
# ════════════════════════════════════════════════════════
FROM node:20-alpine AS deps
RUN apk add --no-cache openssl postgresql-client
WORKDIR /app

# Copy ONLY package files → this layer is cached until deps change
COPY package.json package-lock.json* turbo.json ./
COPY apps/api/package.json ./apps/api/
COPY packages/shared/package.json ./packages/shared/
COPY packages/database/package.json ./packages/database/
RUN --mount=type=cache,target=/root/.npm npm install

# ════════════════════════════════════════════════════════
# Stage 2: Source + prisma generate
# ════════════════════════════════════════════════════════
FROM deps AS base
COPY tsconfig.json ./
COPY packages/shared/ ./packages/shared/
COPY packages/database/ ./packages/database/
COPY apps/api/ ./apps/api/

RUN npx prisma generate --schema=packages/database/prisma/schema.prisma

# ════════════════════════════════════════════════════════
# Stage 2a: Development (hot-reload)
# ════════════════════════════════════════════════════════
FROM base AS development
EXPOSE 3000
CMD sh -c "\
  npx prisma db push --schema=packages/database/prisma/schema.prisma --skip-generate --accept-data-loss && \
  PGPASSWORD=\$POSTGRES_PASSWORD psql -h \${DATABASE_HOST:-postgres} -U \${POSTGRES_USER:-netmon} -d \${POSTGRES_DB:-netmon} -f packages/database/prisma/migrations/timescaledb/create_hypertables.sql 2>/dev/null || true && \
  npx prisma db seed --schema=packages/database/prisma/schema.prisma 2>/dev/null; \
  npm run dev -w apps/api"

# ════════════════════════════════════════════════════════
# Stage 2b: Production build
# ════════════════════════════════════════════════════════
FROM base AS builder
RUN npx turbo build --filter=api

# ════════════════════════════════════════════════════════
# Stage 3: Production runtime (minimal)
# ════════════════════════════════════════════════════════
FROM node:20-alpine AS production
RUN apk add --no-cache openssl dumb-init
WORKDIR /app

ENV NODE_ENV=production
USER node

COPY --from=deps --chown=node:node /app/node_modules ./node_modules
COPY --from=builder --chown=node:node /app/apps/api/dist ./apps/api/dist
COPY --from=base --chown=node:node /app/packages/database/prisma ./packages/database/prisma
COPY --from=deps --chown=node:node /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder --chown=node:node /app/packages/shared/dist ./packages/shared/dist
COPY --from=base --chown=node:node /app/packages/shared/package.json ./packages/shared/
COPY --from=base --chown=node:node /app/packages/database/package.json ./packages/database/
COPY --from=base --chown=node:node /app/apps/api/package.json ./apps/api/
COPY --from=base --chown=node:node /app/package.json ./

EXPOSE 3000
ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "apps/api/dist/main.js"]

# ════════════════════════════════════════════════════════
# Final: select stage based on BUILD_ENV
# ════════════════════════════════════════════════════════
FROM ${BUILD_ENV} AS final
