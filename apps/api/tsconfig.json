{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "baseUrl": "./",
        "typeRoots": [
            "./src/types",
            "../../node_modules/@types"
        ],
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@netmon/shared": [
                "../../packages/shared/src"
            ],
            "@netmon/database": [
                "../../packages/database/src"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}