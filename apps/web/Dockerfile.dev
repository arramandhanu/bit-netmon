# ─── NetMon Web — Unified Dockerfile ─────────────────
# Dev:  docker compose -f infra/docker-compose.dev.yml up
# Prod: docker compose -f infra/docker-compose.prod.yml up
#
# Build arg BUILD_ENV controls the behavior:
#   development → hot-reload with next dev
#   production  → multi-stage optimized build (standalone)

ARG BUILD_ENV=development

# ════════════════════════════════════════════════════════
# Stage 1: Base + dependencies
# ════════════════════════════════════════════════════════
FROM node:20-alpine AS base
WORKDIR /app

COPY package.json package-lock.json* turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

RUN npm install --workspace=apps/web --workspace=packages/shared --include-workspace-root

COPY apps/web/ ./apps/web/
COPY packages/shared/ ./packages/shared/

# ════════════════════════════════════════════════════════
# Stage 2a: Development (hot-reload)
# ════════════════════════════════════════════════════════
FROM base AS development
ENV HOSTNAME="0.0.0.0"
EXPOSE 3001
CMD ["npm", "run", "dev", "-w", "apps/web"]

# ════════════════════════════════════════════════════════
# Stage 2b: Production build
# ════════════════════════════════════════════════════════
FROM base AS builder
ENV NEXT_TELEMETRY_DISABLED=1
RUN npx turbo build --filter=web

# ════════════════════════════════════════════════════════
# Stage 3: Production runtime (minimal)
# ════════════════════════════════════════════════════════
FROM node:20-alpine AS production
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs
EXPOSE 3001
ENV PORT=3001
ENV HOSTNAME="0.0.0.0"
CMD ["node", "apps/web/server.js"]

# ════════════════════════════════════════════════════════
# Final: select stage based on BUILD_ENV
# ════════════════════════════════════════════════════════
FROM ${BUILD_ENV} AS final
