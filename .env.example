# ─── PostgreSQL ───────────────────────────────────
POSTGRES_USER=netmon
POSTGRES_PASSWORD=<YOUR_SECURE_PASSWORD>
POSTGRES_DB=netmon
POSTGRES_PORT=5432
DATABASE_URL=postgresql://netmon:<YOUR_SECURE_PASSWORD>@postgres:5432/netmon?schema=public

# ─── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAXMEMORY=512mb

# ─── App ──────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
WEB_PORT=3001

# ─── Auth ─────────────────────────────────────────
JWT_SECRET=<YOUR_SECURE_JWT_SECRET_MIN_64_CHARS>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ──────────────────────────────────
ENCRYPTION_KEY=<YOUR_SECURE_ENCRYPTION_KEY_32_CHARS>

# ─── SNMP ─────────────────────────────────────────
SNMP_DEFAULT_TIMEOUT=5000
SNMP_DEFAULT_RETRIES=1
SNMP_POLLING_INTERVAL=300

# ─── Logging ─────────────────────────────────────
LOG_LEVEL=debug

# ─── Frontend ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3000

# ─── Notifications (optional) ────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
