// ──────────────────────────────────────────────────────────
// NetMon — Prisma Schema
// ──────────────────────────────────────────────────────────
// All models map to snake_case tables. Prisma fields use
// camelCase for TypeScript ergonomics.
//
// TimescaleDB hypertables (interface_metrics, device_metrics,
// wireless_metrics) are created via raw SQL in a separate
// migration — Prisma does not manage them.
// ──────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum DeviceType {
  router
  switch
  access_point
  firewall
  server
  unknown

  @@map("device_type")
}

enum DeviceStatus {
  up
  down
  warning
  maintenance
  unknown

  @@map("device_status")
}

enum AlertSeverity {
  info
  warning
  critical

  @@map("alert_severity")
}

enum AlertState {
  triggered
  acknowledged
  resolved

  @@map("alert_state")
}

enum UserRole {
  admin
  operator
  viewer
  user

  @@map("user_role")
}

enum TicketStatus {
  open
  in_progress
  waiting
  escalated
  on_hold
  resolved
  closed

  @@map("ticket_status")
}

enum TicketPriority {
  low
  medium
  high
  critical

  @@map("ticket_priority")
}

enum TicketCategory {
  incident
  problem
  change_request
  maintenance
  support_request

  @@map("ticket_category")
}

// ─── Location ───────────────────────────────────────────

model Location {
  id        Int      @id @default(autoincrement()) @map("location_id")
  name      String   @db.VarChar(255)
  code      String   @unique @db.VarChar(50)
  address   String?  @db.Text
  city      String?  @db.VarChar(100)
  province  String?  @db.VarChar(100)
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Multi-tenant
  tenantId       Int?     @map("tenant_id")
  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  devices        Device[]
  serverMonitors ServerMonitor[]
  urlMonitors    UrlMonitor[]

  @@index([tenantId], map: "idx_locations_tenant")
  @@map("locations")
}

// ─── Device ─────────────────────────────────────────────

model Device {
  id               Int          @id @default(autoincrement()) @map("device_id")
  hostname         String       @unique @db.VarChar(255)
  ipAddress        String       @map("ip_address") @db.VarChar(45)
  displayName      String?      @map("display_name") @db.VarChar(255)
  deviceType       DeviceType   @default(unknown) @map("device_type")
  vendor           String?      @db.VarChar(100)
  model            String?      @db.VarChar(100)
  osVersion        String?      @map("os_version") @db.VarChar(255)
  serialNumber     String?      @map("serial_number") @db.VarChar(100)
  sysObjectId      String?      @map("sys_object_id") @db.VarChar(255)
  status           DeviceStatus @default(unknown)

  uptime           BigInt?      @default(0)

  // SNMP credentials (encrypted at rest)
  snmpVersion      String       @default("v2c") @map("snmp_version") @db.VarChar(10)
  snmpPort         Int          @default(161) @map("snmp_port")
  snmpCommunity    String?      @map("snmp_community") @db.VarChar(512)
  snmpV3User       String?      @map("snmp_v3_user") @db.VarChar(255)
  snmpV3AuthProto  String?      @map("snmp_v3_auth_proto") @db.VarChar(10)
  snmpV3AuthPass   String?      @map("snmp_v3_auth_pass") @db.VarChar(512)
  snmpV3PrivProto  String?      @map("snmp_v3_priv_proto") @db.VarChar(10)
  snmpV3PrivPass   String?      @map("snmp_v3_priv_pass") @db.VarChar(512)

  // Polling
  pollingEnabled   Boolean      @default(true) @map("polling_enabled")
  pollingInterval  Int          @default(300) @map("polling_interval")
  lastPolledAt     DateTime?    @map("last_polled_at")
  lastDiscoveredAt DateTime?    @map("last_discovered_at")

  // Relations
  locationId       Int?         @map("location_id")
  location         Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  interfaces       Interface[]
  alertHistory     AlertHistory[]
  groups           DeviceGroupMember[]
  pollingJobs      PollingJob[]
  tickets          Ticket[]

  // Multi-tenant
  tenantId         Int?         @map("tenant_id")
  tenant           Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([locationId], map: "idx_devices_location")
  @@index([status], map: "idx_devices_status")
  @@index([deviceType], map: "idx_devices_type")
  @@index([ipAddress], map: "idx_devices_ip")
  @@index([tenantId], map: "idx_devices_tenant")
  @@map("devices")
}

// ─── Interface ──────────────────────────────────────────

model Interface {
  id               Int      @id @default(autoincrement()) @map("interface_id")
  deviceId         Int      @map("device_id")
  ifIndex          Int      @map("if_index")
  ifName           String?  @map("if_name") @db.VarChar(255)
  ifDescr          String?  @map("if_descr") @db.VarChar(255)
  ifAlias          String?  @map("if_alias") @db.VarChar(255)
  ifType           String?  @map("if_type") @db.VarChar(50)
  ifSpeed          BigInt?  @default(0) @map("if_speed")
  ifHighSpeed      BigInt?  @default(0) @map("if_high_speed")
  ifPhysAddress    String?  @map("if_phys_address") @db.VarChar(50)
  ifAdminStatus    String?  @default("up") @map("if_admin_status") @db.VarChar(20)
  ifOperStatus     String?  @default("up") @map("if_oper_status") @db.VarChar(20)
  pollingEnabled   Boolean  @default(true) @map("polling_enabled")

  device           Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([deviceId, ifIndex], map: "uq_device_ifindex")
  @@index([deviceId], map: "idx_interfaces_device")
  @@index([ifOperStatus], map: "idx_interfaces_status")
  @@map("interfaces")
}

// ─── Alert Rule ─────────────────────────────────────────

model AlertRule {
  id             Int           @id @default(autoincrement()) @map("rule_id")
  name           String        @db.VarChar(255)
  description    String?       @db.Text
  metricName     String        @map("metric_name") @db.VarChar(100)
  condition      String        @db.VarChar(10)
  threshold      Float
  duration       Int           @default(0)
  severity       AlertSeverity @default(warning)
  enabled        Boolean       @default(true)
  notifyChannels String[]      @map("notify_channels")

  deviceGroupId  Int?          @map("device_group_id")
  deviceGroup    DeviceGroup?  @relation(fields: [deviceGroupId], references: [id], onDelete: SetNull)

  alerts         AlertHistory[]

  // Multi-tenant
  tenantId       Int?          @map("tenant_id")
  tenant         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([tenantId], map: "idx_alert_rules_tenant")
  @@map("alert_rules")
}

// ─── Alert History ──────────────────────────────────────

model AlertHistory {
  id             Int           @id @default(autoincrement()) @map("alert_id")
  deviceId       Int           @map("device_id")
  ruleId         Int           @map("rule_id")
  severity       AlertSeverity
  state          AlertState    @default(triggered)
  message        String        @db.Text
  metricValue    Float?        @map("metric_value")
  triggeredAt    DateTime      @default(now()) @map("triggered_at")
  acknowledgedAt DateTime?     @map("acknowledged_at")
  acknowledgedBy Int?          @map("acknowledged_by")
  resolvedAt     DateTime?     @map("resolved_at")

  device         Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  rule           AlertRule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tickets        Ticket[]

  @@index([deviceId, triggeredAt], map: "idx_alerts_device_time")
  @@index([state], map: "idx_alerts_state")
  @@index([severity], map: "idx_alerts_severity")
  @@map("alert_history")
}

// ─── Device Group ───────────────────────────────────────

model DeviceGroup {
  id          Int                 @id @default(autoincrement()) @map("group_id")
  name        String              @unique @db.VarChar(255)
  description String?             @db.Text
  members     DeviceGroupMember[]
  alertRules  AlertRule[]

  // Multi-tenant
  tenantId    Int?                @map("tenant_id")
  tenant      Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([tenantId], map: "idx_device_groups_tenant")
  @@map("device_groups")
}

model DeviceGroupMember {
  groupId  Int         @map("group_id")
  deviceId Int         @map("device_id")
  group    DeviceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  device   Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([groupId, deviceId])
  @@map("device_group_members")
}

// ─── Polling Job ────────────────────────────────────────

model PollingJob {
  id          Int      @id @default(autoincrement()) @map("job_id")
  deviceId    Int      @map("device_id")
  jobType     String   @map("job_type") @db.VarChar(50)
  status      String   @default("pending") @db.VarChar(20)
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  duration    Int?
  error       String?  @db.Text

  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([deviceId, createdAt], map: "idx_polling_jobs_device")
  @@map("polling_jobs")
}

// ─── User ───────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement()) @map("user_id")
  username     String   @unique @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String?  @map("display_name") @db.VarChar(255)
  fullName     String?  @map("full_name") @db.VarChar(255)
  phone        String?  @db.VarChar(50)
  role         UserRole @default(viewer)
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  totpSecret   String?  @map("totp_secret") @db.VarChar(255)
  totpEnabled  Boolean  @default(false) @map("totp_enabled")

  // Email verification
  emailVerified       Boolean   @default(false) @map("email_verified")
  verificationToken   String?   @map("verification_token") @db.VarChar(255)
  verificationExpires DateTime? @map("verification_expires")

  // Multi-tenant
  tenantId     Int?     @map("tenant_id")
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  createdTickets     Ticket[]          @relation("TicketCreator")
  assignedTickets    Ticket[]          @relation("TicketAssignee")
  ticketComments     TicketComment[]
  sentInvitations    TenantInvitation[] @relation("InvitedBy")

  @@index([tenantId], map: "idx_users_tenant")
  @@map("users")
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement()) @map("log_id")
  userId    Int?     @map("user_id")
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  Int?     @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], map: "idx_audit_user")
  @@index([entity, entityId], map: "idx_audit_entity")
  @@map("audit_logs")
}

// ─── System Settings ────────────────────────────────────

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  category  String   @db.VarChar(50)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category], map: "idx_settings_category")
  @@map("system_settings")
}

// ─── API Keys ───────────────────────────────────────────

model ApiKey {
  id        Int       @id @default(autoincrement()) @map("api_key_id")
  userId    Int       @map("user_id")
  name      String    @db.VarChar(100)
  keyHash   String    @map("key_hash") @db.VarChar(255)
  prefix    String    @db.VarChar(12)
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt DateTime?  @map("expires_at")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([prefix], map: "idx_api_keys_prefix")
  @@index([userId], map: "idx_api_keys_user")
  @@map("api_keys")
}

// ─── Ticket ─────────────────────────────────────────────

model Ticket {
  id             Int              @id @default(autoincrement()) @map("ticket_id")
  ticketNumber   String           @unique @map("ticket_number") @db.VarChar(20)
  title          String           @db.VarChar(500)
  description    String           @db.Text
  status         TicketStatus     @default(open)
  priority       TicketPriority   @default(medium)
  category       TicketCategory   @default(incident)
  tags           String[]         @default([])

  // Relations
  deviceId       Int?             @map("device_id")
  device         Device?          @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  alertId        Int?             @map("alert_id")
  alert          AlertHistory?    @relation(fields: [alertId], references: [id], onDelete: SetNull)
  creatorId      Int              @map("creator_id")
  creator        User             @relation("TicketCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assigneeId     Int?             @map("assignee_id")
  assignee       User?            @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Timestamps
  dueDate        DateTime?        @map("due_date")
  resolvedAt     DateTime?        @map("resolved_at")
  closedAt       DateTime?        @map("closed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  comments       TicketComment[]
  attachments    TicketAttachment[]

  @@index([status], map: "idx_tickets_status")
  @@index([priority], map: "idx_tickets_priority")
  @@index([assigneeId], map: "idx_tickets_assignee")
  @@index([deviceId], map: "idx_tickets_device")
  @@index([creatorId], map: "idx_tickets_creator")
  @@index([createdAt], map: "idx_tickets_created")
  @@map("tickets")
}

// ─── Ticket Comment ─────────────────────────────────────

model TicketComment {
  id        Int      @id @default(autoincrement()) @map("comment_id")
  ticketId  Int      @map("ticket_id")
  userId    Int      @map("user_id")
  content   String   @db.Text
  isSystem  Boolean  @default(false) @map("is_system")
  parentId  Int?     @map("parent_id")

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    TicketComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   TicketComment[] @relation("CommentReplies")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ticketId, createdAt], map: "idx_ticket_comments_ticket")
  @@index([parentId], map: "idx_ticket_comments_parent")
  @@map("ticket_comments")
}

// ─── Ticket Attachment ──────────────────────────────────

model TicketAttachment {
  id          Int      @id @default(autoincrement()) @map("attachment_id")
  ticketId    Int      @map("ticket_id")
  uploadedBy  Int      @map("uploaded_by")
  fileName    String   @map("file_name") @db.VarChar(255)
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type") @db.VarChar(100)
  storagePath String   @map("storage_path") @db.VarChar(512)

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([ticketId], map: "idx_ticket_attachments_ticket")
  @@map("ticket_attachments")
}

// ─── Web/API URL Monitors ───────────────────────────────

model UrlMonitor {
  id              Int       @id @default(autoincrement()) @map("url_monitor_id")
  name            String    @db.VarChar(255)
  url             String    @db.VarChar(2048)
  method          String    @default("GET") @db.VarChar(10)
  expectedStatus  Int       @default(200) @map("expected_status")
  checkInterval   Int       @default(300) @map("check_interval")
  timeout         Int       @default(30000)
  headers         Json?
  body            String?   @db.Text
  enabled         Boolean   @default(true)
  status          String    @default("unknown") @db.VarChar(20)
  lastCheckedAt   DateTime? @map("last_checked_at")
  lastResponseMs  Int?      @map("last_response_ms")
  locationId      Int?      @map("location_id")
  location        Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Multi-tenant
  tenantId        Int?      @map("tenant_id")
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([locationId], map: "idx_url_monitors_location")
  @@index([tenantId], map: "idx_url_monitors_tenant")
  @@map("url_monitors")
}

// ─── Server Monitoring ──────────────────────────────────

enum ServerType {
  linux
  windows

  @@map("server_type")
}

model ServerMonitor {
  id              Int        @id @default(autoincrement()) @map("server_id")
  name            String     @db.VarChar(255)
  serverType      ServerType @map("server_type")
  ipAddress       String?    @map("ip_address") @db.VarChar(45)
  hostname        String?    @db.VarChar(255)
  osInfo          String?    @map("os_info") @db.VarChar(500)
  agentToken      String     @unique @map("agent_token") @db.VarChar(255)
  agentVersion    String?    @map("agent_version") @db.VarChar(50)
  agentInterval   Int        @default(300) @map("agent_interval")
  status          String     @default("unknown") @db.VarChar(20)
  lastReportedAt  DateTime?  @map("last_reported_at")
  enabled         Boolean    @default(true)
  monitorOptions  Json?      @map("monitor_options")
  locationId      Int?       @map("location_id")
  location        Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Multi-tenant
  tenantId        Int?       @map("tenant_id")
  tenant          Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([status], map: "idx_server_monitors_status")
  @@index([agentToken], map: "idx_server_monitors_token")
  @@index([locationId], map: "idx_server_monitors_location")
  @@index([tenantId], map: "idx_server_monitors_tenant")
  @@map("server_monitors")
}

// ─── Billing: Enums ─────────────────────────────────────

enum SubscriptionStatus {
  trial
  active
  past_due
  suspended
  cancelled

  @@map("subscription_status")
}

enum PaymentStatus {
  pending
  paid
  failed
  expired
  refunded

  @@map("payment_status")
}

// ─── Billing: Tenant ────────────────────────────────────

model Tenant {
  id            Int      @id @default(autoincrement()) @map("tenant_id")
  name          String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(100)
  contactEmail  String   @map("contact_email") @db.VarChar(255)
  contactPhone  String?  @map("contact_phone") @db.VarChar(50)
  company       String?  @db.VarChar(255)
  isActive      Boolean  @default(true) @map("is_active")

  users          User[]
  subscriptions  Subscription[]
  invoices       Invoice[]
  devices        Device[]
  locations      Location[]
  serverMonitors ServerMonitor[]
  urlMonitors    UrlMonitor[]
  deviceGroups   DeviceGroup[]
  alertRules     AlertRule[]
  invitations    TenantInvitation[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([slug], map: "idx_tenants_slug")
  @@map("tenants")
}

// ─── Billing: Plan ──────────────────────────────────────

model Plan {
  id                  Int      @id @default(autoincrement()) @map("plan_id")
  name                String   @unique @db.VarChar(100)
  slug                String   @unique @db.VarChar(100)
  description         String?  @db.Text
  priceMonthly        Int      @default(0) @map("price_monthly")
  priceYearly         Int?     @map("price_yearly")
  currency            String   @default("IDR") @db.VarChar(5)

  // Limits
  maxDevices          Int      @default(5) @map("max_devices")
  maxServers          Int      @default(2) @map("max_servers")
  maxUrlMonitors      Int      @default(3) @map("max_url_monitors")
  maxUsers            Int      @default(1) @map("max_users")
  dataRetentionDays   Int      @default(7) @map("data_retention_days")
  minPollingInterval  Int      @default(600) @map("min_polling_interval")

  // Feature flags (JSON)
  features            Json     @default("{}")

  isPublic            Boolean  @default(true) @map("is_public")
  sortOrder           Int      @default(0) @map("sort_order")

  subscriptions       Subscription[]

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

// ─── Billing: Subscription ──────────────────────────────

model Subscription {
  id                  Int                @id @default(autoincrement()) @map("subscription_id")
  tenantId            Int                @map("tenant_id")
  planId              Int                @map("plan_id")
  status              SubscriptionStatus @default(trial)
  trialEndsAt         DateTime?          @map("trial_ends_at")
  currentPeriodStart  DateTime           @map("current_period_start")
  currentPeriodEnd    DateTime           @map("current_period_end")
  cancelledAt         DateTime?          @map("cancelled_at")

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments            Payment[]
  invoices            Invoice[]

  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@index([tenantId], map: "idx_subscriptions_tenant")
  @@index([status], map: "idx_subscriptions_status")
  @@map("subscriptions")
}

// ─── Billing: Payment ───────────────────────────────────

model Payment {
  id                  Int           @id @default(autoincrement()) @map("payment_id")
  subscriptionId      Int           @map("subscription_id")
  midtransOrderId     String        @unique @map("midtrans_order_id") @db.VarChar(100)
  midtransTransId     String?       @map("midtrans_trans_id") @db.VarChar(100)
  snapToken           String?       @map("snap_token") @db.VarChar(255)
  snapRedirectUrl     String?       @map("snap_redirect_url") @db.VarChar(512)
  amount              Int
  currency            String        @default("IDR") @db.VarChar(5)
  status              PaymentStatus @default(pending)
  paymentType         String?       @map("payment_type") @db.VarChar(50)
  paidAt              DateTime?     @map("paid_at")
  rawNotification     Json?         @map("raw_notification")

  subscription        Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@index([subscriptionId], map: "idx_payments_subscription")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

// ─── Billing: Invoice ───────────────────────────────────

model Invoice {
  id                  Int       @id @default(autoincrement()) @map("invoice_id")
  invoiceNumber       String    @unique @map("invoice_number") @db.VarChar(50)
  tenantId            Int       @map("tenant_id")
  subscriptionId      Int       @map("subscription_id")
  amount              Int
  currency            String    @default("IDR") @db.VarChar(5)
  periodStart         DateTime  @map("period_start")
  periodEnd           DateTime  @map("period_end")
  status              String    @default("unpaid") @db.VarChar(20)
  paidAt              DateTime? @map("paid_at")

  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription        Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([tenantId], map: "idx_invoices_tenant")
  @@index([subscriptionId], map: "idx_invoices_subscription")
  @@map("invoices")
}

// ─── Tenant Invitation ──────────────────────────────────

model TenantInvitation {
  id          Int       @id @default(autoincrement()) @map("invitation_id")
  tenantId    Int       @map("tenant_id")
  email       String    @db.VarChar(255)
  role        UserRole  @default(viewer)
  token       String    @unique @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  invitedById Int       @map("invited_by_id")

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])

  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId], map: "idx_invitations_tenant")
  @@index([token], map: "idx_invitations_token")
  @@map("tenant_invitations")
}
